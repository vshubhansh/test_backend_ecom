# App — port the server listens on (also the container-side port in compose).
PORT=3005
# Host-side port for the app container in docker compose (change if taken).
APP_PORT=3005

# Database — DB_HOST is overridden to "mysql" inside docker compose.
# Use 127.0.0.1 when running the app directly on the host against the compose MySQL.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ecom_app
DB_PASSWORD=ecom_app_password
DB_NAME=ecom
DB_POOL_LIMIT=15

# Used only by the MySQL container itself.
MYSQL_ROOT_PASSWORD=root_password

# Background worker tick (5 minutes). Lower it for local demos/tests.
WORKER_INTERVAL_MS=300000
